# Amazon Advertising API 인증
AMAZON_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AMAZON_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AMAZON_REFRESH_TOKEN=Atzr|xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AMAZON_PROFILE_ID=0000000000000        # 광고 프로필 ID (Advertising Console에서 확인)
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER   # US 마켓플레이스 (변경 필요 시 수정)

# 최적화 설정
TARGET_ROAS=5.0
TARGET_ACOS=0.20

# 서버 설정
API_PORT=8000
LOG_LEVEL=INFO                         # DEBUG / INFO / WARNING / ERROR

# DB
DATABASE_URL=sqlite+aiosqlite:///./dashboard.db
